{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "openradar-risk",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-14",
  "send_metrics": false,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
