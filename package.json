{
  "name": "openrisk-radar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && wrangler deploy",
    "lint": "eslint .",
    "worker:check": "wrangler deploy --dry-run --outdir .wrangler/tmp/worker",
    "worker:dev": "npm run build && wrangler dev",
    "preview": "vite preview",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@turf/turf": "^7.1.0",
    "dexie": "^4.0.8",
    "leaflet": "^1.9.4",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.14",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
